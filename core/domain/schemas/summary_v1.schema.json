{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worlds.local/schemas/summary_v1.schema.json",
  "title": "ParseAndSyncSummaryV1",
  "type": "object",
  "required": [
    "schema_version",
    "pipeline_build",
    "request_id",
    "sync_enabled",
    "sync_message",
    "second_pass"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "pipeline_build": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "sync_enabled": {
      "type": "boolean"
    },
    "sync_message": {
      "type": "string"
    },
    "second_pass": {
      "type": "object"
    },
    "error": {
      "type": "string"
    },
    "pipeline_status": {
      "type": "string"
    },
    "pipeline": {
      "type": "object"
    },
    "stage_statuses": {
      "type": "array"
    },
    "stats": {
      "type": "object"
    },
    "phrase_matches": {
      "type": "array"
    },
    "lexemes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "phrasal_verbs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "added": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "already_existed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejected_candidates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "queued_for_sync": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sync_async": {
      "type": "boolean"
    },
    "sync_stage_status": {
      "type": "object"
    },
    "lexicon_version": {},
    "lexicon_file": {
      "type": "string"
    },
    "category_review_required": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
