# Default local runtime template.
# Copy to `.env` and adjust only if you want to override defaults.

START_LEGACY_BACKEND=0
GATEWAY_PARSE_BACKEND=nlp
GATEWAY_LEXICON_BACKEND=service
GATEWAY_ASSIGNMENTS_BACKEND=service
GATEWAY_STATISTICS_BACKEND=composed
GATEWAY_EXPORT_BACKEND=service

# Owner services run on Postgres only.
OWNER_SERVICES_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/vocabulary
LEXICON_POSTGRES_SCHEMA=lexicon
ASSIGNMENTS_POSTGRES_SCHEMA=assignments

# LLM third pass (managed llama.cpp or vLLM service)
# Local default: llama.cpp + GGUF.
# For llama.cpp:
#   1. Install/build `llama-server`
#   2. Download a GGUF model and set LLM_SERVICE_MODEL_PATH
# Optional vLLM path:
#   docker pull vllm/vllm-openai-rocm:latest
GATEWAY_JOB_TTL_MS=420000
LLM_SERVICE_ENABLED=false
LLM_SERVICE_RUNTIME=llama_cpp
LLM_SERVICE_MODEL=Qwen3.5-9B-GGUF
LLM_SERVICE_EXECUTABLE=llama-server
LLM_SERVICE_MODEL_PATH=
LLM_SERVICE_PORT=8000
LLM_SERVICE_MAX_MODEL_LEN=8192
THIRD_PASS_LLM_TIMEOUT_MS=300000
LLM_SERVICE_N_GPU_LAYERS=-1
