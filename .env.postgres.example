# Host-run Postgres template for `./start.sh`.
# By default `start.sh` will auto-start local `docker compose up -d postgres`
# when OWNER_SERVICES_POSTGRES_URL points to localhost / 127.0.0.1.
# Run `./scripts/prepare_docker_runtime.sh` once first, so startup reuses
# a preloaded local postgres image and does not download on boot.
# Postgres data is persisted on the host via POSTGRES_DATA_DIR.
# The actual cluster is created inside PGDATA subdirectory under that mount.
# Set START_POSTGRES_VIA_COMPOSE=0 if you want to use an already running external Postgres.

POSTGRES_DATA_DIR=./docker-data/postgres
START_LEGACY_BACKEND=0

GATEWAY_PARSE_BACKEND=nlp
GATEWAY_LEXICON_BACKEND=service
GATEWAY_ASSIGNMENTS_BACKEND=service
GATEWAY_STATISTICS_BACKEND=composed
GATEWAY_EXPORT_BACKEND=service

OWNER_SERVICES_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/vocabulary
START_POSTGRES_VIA_COMPOSE=1
LEXICON_POSTGRES_SCHEMA=lexicon
ASSIGNMENTS_POSTGRES_SCHEMA=assignments
