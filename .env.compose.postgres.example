# Docker Compose Postgres template.
# Assumes `docker compose up` or `docker compose --env-file .env.compose.postgres up`
# and container-to-container DSN.
# Run `./scripts/prepare_docker_runtime.sh` once before startup so compose
# uses prebuilt local runtime images and does not download/install on boot.
# Postgres data is persisted on the host filesystem via POSTGRES_DATA_DIR.
# The actual cluster is created inside PGDATA subdirectory under that mount.

START_LEGACY_BACKEND=0
POSTGRES_DATA_DIR=./docker-data/postgres

GATEWAY_PARSE_BACKEND=nlp
GATEWAY_LEXICON_BACKEND=service
GATEWAY_ASSIGNMENTS_BACKEND=service
GATEWAY_STATISTICS_BACKEND=composed
GATEWAY_EXPORT_BACKEND=service

OWNER_SERVICES_STORAGE_BACKEND=postgres
OWNER_SERVICES_POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/vocabulary
OWNER_SERVICES_POSTGRES_BOOTSTRAP_FROM_SQLITE=1
LEXICON_POSTGRES_SCHEMA=lexicon
ASSIGNMENTS_POSTGRES_SCHEMA=assignments
PYTHON_RUNTIME_REQUIREMENTS_FILE=requirements.compose.txt
PYTHON_RUNTIME_IMAGE_TAG=local
NODE_RUNTIME_IMAGE_TAG=local
