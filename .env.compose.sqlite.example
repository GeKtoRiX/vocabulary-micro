# Explicit SQLite fallback for Docker Compose.
# Postgres container may still start, but owner services will stay on SQLite.
# Run `./scripts/prepare_docker_runtime.sh` once before `docker compose up`
# so startup reuses prebuilt local images without downloading dependencies.
# If the postgres service is started, its data is persisted on the host via POSTGRES_DATA_DIR.
# The actual cluster is created inside PGDATA subdirectory under that mount.

START_LEGACY_BACKEND=0
POSTGRES_DATA_DIR=./docker-data/postgres

GATEWAY_PARSE_BACKEND=nlp
GATEWAY_LEXICON_BACKEND=service
GATEWAY_ASSIGNMENTS_BACKEND=service
GATEWAY_STATISTICS_BACKEND=composed
GATEWAY_EXPORT_BACKEND=service

OWNER_SERVICES_STORAGE_BACKEND=sqlite
OWNER_SERVICES_POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/vocabulary
OWNER_SERVICES_POSTGRES_BOOTSTRAP_FROM_SQLITE=0
PYTHON_RUNTIME_IMAGE_TAG=local
NODE_RUNTIME_IMAGE_TAG=local
